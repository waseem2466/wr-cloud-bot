
# WR POS Cloud Bot Environment Variables
# MUST USE POSTGRES FOR CLOUD
WRPOS_DB_DRIVER=postgres
DATABASE_URL=your_neon_db_url_here

# AI Keys
GEMINI_API_KEY=your_gemini_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash-lite
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Owner Configuration
OWNER_PHONE=0719336848
WATCHED_GROUPS=smile and supplies

# WhatsApp auth persistence
# On Koyeb, mount a persistent volume and set this to a path inside it.
# Example: AUTH_DIR=/data/baileys_auth_info
AUTH_DIR=baileys_auth_info
AUTH_ZIP=auth.bin

# POS-to-Koyeb bill sending. Use the same value in the POS .env as WHATSAPP_RELAY_SECRET.
SEND_API_SECRET=change_this_to_a_long_random_password
